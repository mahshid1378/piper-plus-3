# Ensure shell scripts always use LF line endings (required for Docker/Linux)
*.sh text eol=lf

# Ensure Python scripts use LF
*.py text eol=lf

# C/C++ source files
*.c text eol=lf
*.cpp text eol=lf
*.h text eol=lf
*.hpp text eol=lf

# C# files
*.cs text eol=lf
*.csproj text eol=lf
*.sln text eol=lf
*.props text eol=lf
*.targets text eol=lf
*.runsettings text eol=lf

# CMake files
CMakeLists.txt text eol=lf
*.cmake text eol=lf

# Docker files
Dockerfile* text eol=lf
.dockerignore text eol=lf

# Windows scripts (keep CRLF)
*.bat text eol=crlf
*.ps1 text eol=crlf
