{
  "model": {
    "type": "vits",
    "generator": {
      "type": "hifigan",
      "resblock": "1",
      "resblock_kernel_sizes": [3, 7, 11],
      "resblock_dilation_sizes": [[1, 3, 5], [1, 3, 5], [1, 3, 5]],
      "upsample_rates": [8, 8, 2, 2],
      "upsample_initial_channel": 512,
      "upsample_kernel_sizes": [16, 16, 4, 4]
    },
    "vocoder": {
      "type": "hifigan",
      "version": "v1"
    },
    "text_encoder": {
      "type": "transformer",
      "n_layers": 6,
      "n_heads": 2,
      "hidden_channels": 192,
      "filter_channels": 768,
      "kernel_size": 3,
      "p_dropout": 0.1
    },
    "flow": {
      "type": "residual_coupling",
      "n_layers": 4,
      "n_flows": 4,
      "kernel_size": 5,
      "dilation_rate": 1
    },
    "duration_predictor": {
      "filter_channels": 256,
      "kernel_size": 3,
      "p_dropout": 0.5
    }
  },
  "data": {
    "text_cleaners": ["openjtalk_cleaners"],
    "phoneme_type": "openjtalk",
    "language": "ja",
    "sampling_rate": 22050,
    "filter_length": 1024,
    "hop_length": 256,
    "win_length": 1024,
    "n_mel_channels": 80,
    "mel_fmin": 0,
    "mel_fmax": null,
    "num_symbols": 58,
    "preserve_unvoiced": true
  },
  "train": {
    "batch_size": 16,
    "eval_batch_size": 8,
    "num_workers": 4,
    "max_epochs": 10000,
    "learning_rate": 0.0002,
    "betas": [0.8, 0.99],
    "eps": 1e-9,
    "weight_decay": 0.0,
    "grad_clip_thresh": 1.0,
    "lr_decay": 0.999875,
    "segment_size": 8192,
    "init_lr_ratio": 1,
    "warmup_epochs": 0,
    "c_mel": 45,
    "c_kl": 1.0,
    "eval_interval": 1000,
    "log_interval": 100,
    "save_interval": 5000,
    "checkpoint_path": "./checkpoints/ja_JP_css10_openjtalk_unvoiced",
    "logger": {
      "type": "tensorboard",
      "log_dir": "./logs/ja_JP_css10_openjtalk_unvoiced"
    }
  },
  "inference": {
    "noise_scale": 0.667,
    "length_scale": 1.0,
    "noise_w": 0.8,
    "max_len": null
  }
}