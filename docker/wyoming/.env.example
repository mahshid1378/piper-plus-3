# piper-plus Wyoming adapter settings
# Copy to .env and adjust as needed:  cp .env.example .env

# Model: alias ("tsukuyomi", "base"), HuggingFace repo, or path inside container
PIPER_MODEL=tsukuyomi

# Default language for synthesis (ja, en, zh, es, fr, pt)
PIPER_LANGUAGE=ja

# Speaker ID (0 for single-speaker models)
PIPER_SPEAKER_ID=0

# Host port mapping (Wyoming standard: 10200)
PIPER_PORT=10200
